{
  "name": "nekode-ide",
  "version": "0.0.1",
  "description": "Terminal IDE that multiplexes 4 Claude Code instances",
  "type": "module",
  "bin": {
    "nekode": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "format:write": "prettier --write 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck",
    "postinstall": "chmod +x node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "@xterm/headless": "^6.0.0",
    "ink": "^5.2.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/react": "^18.3.18",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.23.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0",
    "vitest": "^3.1.1"
  }
}
